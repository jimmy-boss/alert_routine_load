# Doris Routine Load 告警系统配置文件
# 复制本文件为 alert.yaml 并填入实际值

# Doris FE 连接信息 (仅独立运行模式需要, 作为第三方库使用时可省略, 由调用方传入 *gorm.DB)
doris:
  host: "127.0.0.1"
  port: 9030              # 默认 9030
  user: "root"
  password: "your-password-here"

# 飞书 Webhook 配置
feishu:
  webhook_url: "https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id"
  sign_secret: ""         # 可选: 飞书签名密钥

# 告警策略
alert:
  scan_interval: "60s"              # 扫描间隔 (支持: 30s, 1m, 5m 等格式)
  default_initial_interval: "5m"    # 首次告警后的最小间隔
  default_max_interval: "60m"       # 最大间隔上限
  default_backoff_factor: 2.0       # 每次发送后间隔倍增系数
  error_truncate_len: 300           # 错误详情截断长度 (字符)
  fetch_error_url: true             # 是否获取错误 URL 详情
  error_url_timeout: "5s"           # 错误 URL 请求超时
  # 告警历史持久化
  history:
    enabled: true                   # 是否启用告警历史, 默认 true
    dir: "data"                     # 持久化目录 (相对于程序运行目录)
    max_age: "720h"                 # 归档记录保留时长 (30 天)

# 数据库扫描模式 (可选, 不配置则使用白名单模式)
# scan_databases:
#   mode: "all"                         # "all" = 自动发现所有数据库 | "configured" = 仅 database 段 (默认)
#   exclude:                            # 精确排除 (在系统库内置过滤之上叠加)
#     - "tmp_db"
#     - "staging"
#   exclude_patterns:                   # 正则排除
#     - "^test_.*"
#     - ".*_backup$"
#   override_system_databases:          # 追加内置系统库排除列表 (默认: information_schema, __internal_schema, mysql)
#     - "__statistics__"

# 监控规则: 按数据库 → 作业粒度配置 (mode=configured 时必填, mode=all 时可选用于精细覆盖)
database:
  - database: "your_database"
    alert:                            # 数据库级覆盖 (可选)
      initial_interval: "2m"
    jobs:
      - name: "your_routine_load_job"
        alert:                        # 作业级覆盖 (可选, 最高优先级)
          initial_interval: "1m"
          backoff_factor: 3.0

  # 监控整个数据库的所有作业 (使用全局默认参数)
  - database: "another_database"
